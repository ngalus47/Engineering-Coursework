{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc-10 build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-Wall",
                "-O5",
                "-pthread",
                "${fileDirname}/*.c",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-lrt",
                "-lGL",
                "-lpigpiod_if2",
                "-lraylib",
                 "-lm", 
                 "-lpthread", 
                 "-ldl", 
                 "-lX11"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}
